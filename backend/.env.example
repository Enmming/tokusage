# Copy to .env and edit for local development.

# Async SQLAlchemy URL. Matches docker-compose service name.
TOKUSAGE_DATABASE_URL=postgresql+asyncpg://tokusage:tokusage@localhost:5432/tokusage

# Comma-separated list of accepted Bearer tokens. In production, replace
# this with per-user tokens issued from your SSO / admin panel.
TOKUSAGE_VALID_TOKENS=devtoken,demotoken
